    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.20.0",
